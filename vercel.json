{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/route.js": {
      "memory": 2048,
      "maxDuration": 300,
      "includeFiles": "routing/{lib,regional,schema}/**"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
